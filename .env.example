# KCLS BiblioCommons tokens
# Get from Chrome DevTools > Application > Cookies > bibliocommons.com
KCLS_ACCESS_TOKEN=your-bc_access_token-cookie-value
KCLS_SESSION_ID=your-session_id-cookie-value

# Libby / OverDrive bearer token
# Get from Chrome DevTools on libbyapp.com > Network > filter "sentry" > Authorization header (without "Bearer " prefix)
LIBBY_BEARER_TOKEN=your-jwt-token-here
