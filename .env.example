# KCLS BiblioCommons tokens
# Get from Chrome DevTools > Application > Cookies > bibliocommons.com
KCLS_ACCESS_TOKEN=your-bc_access_token-cookie-value
KCLS_SESSION_ID=your-session_id-cookie-value

# Libby / OverDrive bearer token
# Get from Chrome DevTools on libbyapp.com > Network > filter "sentry" > Authorization header (without "Bearer " prefix)
LIBBY_BEARER_TOKEN=your-jwt-token-here

# Goodreads tokens
# CSRF: from meta[name="csrf-token"] on any goodreads.com page
# Cookie: full cookie string from any goodreads.com request (DevTools > Network > copy as cURL)
GOODREADS_CSRF=your-csrf-token
GOODREADS_COOKIE=your-full-cookie-string

# StoryGraph tokens
# CSRF: from meta[name="csrf-token"] on any app.thestorygraph.com page
# Cookie: full cookie string from any app.thestorygraph.com request
STORYGRAPH_CSRF=your-csrf-token
STORYGRAPH_COOKIE=your-full-cookie-string
